---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { categories, getArticlesByCategory, getCategoryUrl, isArticle } from '../lib/blog';

const posts = (await getCollection('posts')).filter(isArticle);
---

<BaseLayout>
  <section class="home-hero">
    <div>
      <p class="eyebrow">Front-end engineering notes</p>
      <h1>FBB Blog</h1>
      <p class="hero-copy">记录前端工程、React、Node 与一些认真折腾过的技术笔记。</p>
      <div class="hero-actions">
        <a class="primary-link" href={getCategoryUrl(categories[0])}>开始阅读</a>
        <a class="secondary-link" href="https://github.com/LuckyFBB" target="_blank" rel="noreferrer">
          GitHub
        </a>
      </div>
    </div>
    <div class="hero-panel" aria-label="博客统计">
      <span>Articles</span>
      <strong>{posts.length}</strong>
      <p>React、Node、工程化、数据结构和 AI 笔记持续整理中。</p>
    </div>
  </section>

  <section class="section">
    <div class="section-heading">
      <h2>分类</h2>
      <span>{posts.length} 篇文章</span>
    </div>
    <div class="category-grid">
      {
        categories.map((category) => {
          const categoryPosts = getArticlesByCategory(posts, category);
          return (
            <a class="category-card" href={getCategoryUrl(category)}>
              <strong>{category.title}</strong>
              <p>{category.description}</p>
              <small>{categoryPosts.length} 篇</small>
            </a>
          );
        })
      }
    </div>
  </section>
</BaseLayout>
